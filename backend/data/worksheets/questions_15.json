      "id": "q1",
      "type": "multiple_choice",
      "prompt": "A water tank holds 40 L when full. It is 3/5 full. How many litres are in the tank?",
      "choices": ["20 L", "22 L", "24 L", "28 L"],
      "answer": "24 L",
      "hint": true,
      "hintContext": "Find 3/5 of 40: (3 × 40) ÷ 5."
