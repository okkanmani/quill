    {
      "id": "q2",
      "type": "multiple_choice",
      "prompt": "A ribbon is 2/3 m long. You cut off 1/6 m. How much ribbon is left?",
      "choices": ["1/6 m", "1/3 m", "1/2 m", "5/6 m"],
      "answer": "1/2 m",
      "hint": true,
      "hintContext": "Use sixths: 2/3 = 4/6. Subtract 1/6."
    },
    {
      "id": "q3",
      "type": "multiple_choice",
